# https://ghostty.org/docs/config

# shift+command+, to reload config
# command+Enter = toggle fullscreen!!
# ctrl+alt+super+space = toggle quick terminal
# option-click to navigate command line!!


# theme
theme = Catppuccin Mocha


# command = tmux  # Fails on macOS: login runs bash -c "exec -l tmux". Use shell RC instead:
#   [[ "$TERM" == *ghostty* && -z "$TMUX" ]] && exec tmux

# ghostty supports nerd fonts natively.
#   Hasklug Nerd Font Mono -> Hasklig Font Mono
#
# Variable fonts: Monaspace Argon, Krypton, Neon, Radon, Xenon
#   wght (weight), slnt (slant), ital (italic),
#   opsz (optical size), wdth (width), GRAD (gradient)
font-family = Monaspace Neon Var
font-size = 18
font-variation = wght=400
font-variation-bold = wght=700


# spacing
adjust-cell-width = 0%
adjust-cell-height = 0%
# adjust-icon-height = -30%


# cursor - block, bar, underline, block_hollow
cursor-style = bar
cursor-style-blink = false
cursor-click-to-move = true
cursor-color = ff5524
cursor-opacity = 1


# window
macos-icon = glass
window-padding-x = 30
window-padding-y = 5,15
window-padding-balance = false
macos-window-shadow = false
quit-after-last-window-closed = true
confirm-close-surface = false
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
title = " "


# background
background-opacity = 1
# false, true, 0 to 20
background-blur = false


# selection
copy-on-select = clipboard
selection-background = 004d89
selection-foreground = e0e7ed


# native ghostty splits
keybind = super+slash=new_split:down
keybind = super+backslash=new_split:right
keybind = super+w=close_surface
keybind = shift+left=goto_split:left
keybind = shift+down=goto_split:down
keybind = shift+up=goto_split:up
keybind = shift+right=goto_split:right

# tmux splits
split-divider-color = 083e6c
# keybind = super+slash=text:\x01\x22
# keybind = super+backslash=text:\x01%
# keybind = shift+left=text:\x01\x1b[D
# keybind = shift+down=text:\x01\x1b[B
# keybind = shift+up=text:\x01\x1b[A
# keybind = shift+right=text:\x01\x1b[C
focus-follows-mouse = true


# quick terminal
keybind = global:alt+enter=toggle_quick_terminal
quick-terminal-position = center
# quick-terminal-size = 50%

# Keybindings
keybind = shift+enter=text:\n
keybind = super+k=text:\x0c

# ctrl+number for tmux window switching (CSI u encoding)
keybind = ctrl+one=text:\x1b[49;5u
keybind = ctrl+two=text:\x1b[50;5u
keybind = ctrl+three=text:\x1b[51;5u
