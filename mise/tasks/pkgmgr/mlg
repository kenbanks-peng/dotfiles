#!/usr/bin/env nu
# [MISE] description="List mise global tools"
# [MISE] dir="{{cwd}}"

let global_config = ($env.DOTFILES | path join "mise" "mise.toml" | path expand)
let metadata = (open ($env.FILE_PWD? | default (pwd) | path join "tools.nuon"))

let rows = (mise list
  | lines
  | each {|line| $line | split row -r '\s+'}
  | where {|parts| ($parts | length) >= 3}
  | each {|parts|
      let raw_source = ($parts | get 2)
      let source = if ($raw_source | str starts-with "~") or ($raw_source | str starts-with "/") {
          $raw_source | str replace "~" $env.HOME | path expand
      } else { "" }
      let name = ($parts | get 0 | split row -r '[:/]' | last)
      let meta = ($metadata | where command == $name | get -o 0)
      let desc = ($meta | get -o desc | default "")
      {name: $name version: ($parts | get 1) desc: $desc source: $source}
    })

let global = ($rows | where source == $global_config | sort-by name)

if ($global | is-empty) { return }

let col_width = ($global | each {|r| $"($r.name) ($r.version)" | str length} | math max)

print $"(ansi green)GLOBAL(ansi reset)"
for r in $global {
  let col = ($"($r.name) ($r.version)" | fill -w $col_width)
  print $"  ($col)  (ansi grey)($r.desc)(ansi reset)"
}
