#!/usr/bin/env zsh
# [MISE] description="Mise list by category"
# [MISE] dir="{{cwd}}"

# mise list by category

set -- ${=@}
len=$#

mise_output=$(mise list | awk '{print $1, $2}')
purple="\033[95m"
reset="\033[0m"
header="Tool Version"

# Format output with aligned columns, applying header coloring
format_table() {
  local data="$1"
  if [[ -n "$data" ]]; then
    (echo "$header"; echo -e "$data") | column -t | while IFS= read -r line; do
      if [[ "$line" == Tool* ]]; then
        echo -e "${purple}${line}${reset}"
      else
        echo "$line"
      fi
    done
  fi
}

if [ $len = 1 ]; then
  output=$(echo "$mise_output" | grep "^$1:")
  if [[ -n "$output" ]]; then
    format_table "$output"
  fi
else
  ungrouped=$(echo "$mise_output" | grep -v ":")
  prefixes=$(echo "$mise_output" | grep ":" | cut -d: -f1 | sort -u)

  if [[ -n "$ungrouped" ]] || [[ -n "$prefixes" ]]; then
    all_data=""
    declare -a section_markers=()
    line_count=0

    if [[ -n "$ungrouped" ]]; then
      section_markers+=("1:MISE")
      all_data="$ungrouped"
      line_count=$(echo -e "$ungrouped" | wc -l | tr -d ' ')
    fi

    for prefix in ${=prefixes}; do
      section_start=$((line_count + 1))
      section_name=$(echo "$prefix" | tr '[:lower:]' '[:upper:]')
      section_markers+=("$section_start:$section_name")

      prefix_tools=$(echo "$mise_output" | grep "^$prefix:")
      if [[ -n "$prefix_tools" ]]; then
        if [[ -n "$all_data" ]]; then
          all_data="$all_data\n$prefix_tools"
        else
          all_data="$prefix_tools"
        fi
        line_count=$((line_count + $(echo "$prefix_tools" | wc -l | tr -d ' ')))
      fi
    done

    formatted=$(echo -e "$header\n$all_data" | column -t)

    current_line=0
    echo -e "$formatted" | while IFS= read -r line; do
      if [[ $current_line -eq 0 ]]; then
        echo -e "${purple}${line}${reset}"
      else
        for marker in "${section_markers[@]}"; do
          marker_line="${marker%%:*}"
          marker_name="${marker#*:}"
          if [[ $current_line -eq $marker_line ]]; then
            echo
            echo -e "${purple}${marker_name}${reset}"
            break
          fi
        done
        echo "$line"
      fi
      ((current_line++))
    done
  fi
fi
