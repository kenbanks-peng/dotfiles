#!/usr/bin/env bash
# Symlink all executables from index.nuon into $BINPATH

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
INDEX="$SCRIPT_DIR/index.nuon"

if [[ -z "${BINPATH:-}" ]]; then
  echo "error: BINPATH is not set" >&2
  exit 1
fi

if [[ ! -d "$BINPATH" ]]; then
  echo "error: BINPATH directory does not exist: $BINPATH" >&2
  exit 1
fi

# Parse name and path from each record in index.nuon
grep -oE '\{[^}]+\}' "$INDEX" | while IFS= read -r entry; do
  name=$(echo "$entry" | sed -n 's/.*name: *\([^,}]*\).*/\1/p' | xargs)
  epath=$(echo "$entry" | sed -n 's/.*path: *\([^,}]*\).*/\1/p' | xargs)

  [[ -z "$name" || -z "$epath" ]] && continue

  target="$SCRIPT_DIR/$epath"
  link="$BINPATH/$name"

  if [[ ! -e "$target" ]]; then
    echo "skip: $name (not found: $epath)"
    continue
  fi

  if [[ -L "$link" && "$(readlink "$link")" == "$target" ]]; then
    continue
  fi

  ln -sf "$target" "$link"
  echo "link: $name -> $epath"
done
